{\n  \"name\": \"ms_fashions\",\n  \"version\": \"1.0.0\",\n  \"description\": \"A complete e-commerce application for fashion products.\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"start\": \"node server/index.js\",\n    \"dev\": \"concurrently 'npm run server' 'npm run client' 'npm run admin'\",\n    \"server\": \"nodemon server/index.js\",\n    \"client\": \"npm start --prefix client\",\n    \"admin\": \"npm start --prefix admin\",\n    \"build\": \"npm run build --prefix client\"\n  },\n  \"repository\": {\n    \"type\": \"git\",\n    \"url\": \"https://github.com/sufianx1/ms_fashions.git\"\n  },\n  \"author\": \"Sufian X\",\n  \"license\": \"ISC\",\n  \"dependencies\": {\n    \"express\": \"^4.17.1\",\n    \"mongoose\": \"^5.10.9\",\n    \"cors\": \"^2.8.5\",\n    \"body-parser\": \"^1.19.0\",\n    \"dotenv\": \"^8.2.0\"\n  },\n  \"devDependencies\": {\n    \"nodemon\": \"^2.0.4\",\n    \"concurrently\": \"^5.3.0\"\n  }\n}